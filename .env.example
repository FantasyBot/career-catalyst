OPENAI_API_KEY=sk-proj-...    # OpenAI API key — used by every LLM node (gpt-4o, gpt-4o-mini)
TAVILY_API_KEY=tvly-...       # Tavily search API — market_scout + job_hunter

# Optional but strongly recommended — raises GitHub rate limit from 60 → 5000 req/hr
# Scopes needed: none (public_repo read is sufficient for unauthenticated access)
GITHUB_TOKEN=ghp_...

# Optional — LangSmith tracing (https://smith.langchain.com)
# When enabled, every graph run, LLM call, Tavily search, and GitHub fetch is traced.
# Note: the CV text and generated outputs are uploaded to LangSmith as trace
# inputs/outputs. Disable tracing or self-host if this is a concern.
#
# Set LANGSMITH_ENDPOINT to match the region your workspace lives in:
#   US (default) : https://api.smith.langchain.com
#   EU           : https://eu.api.smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=career-catalyst